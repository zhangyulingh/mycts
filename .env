# open 运行 npm run dev 时自动打开浏览器
VITE_OPEN=false

# 打包是否开启 cdn
VITE_OPEN_CDN=false

VITE_PUBLIC_PATH=

# 前端 API（Vite 开发代理到 3000）
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://127.0.0.1:3000

# Node 后端（app.js 通过 dotenv 读取）
PORT=3000
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=mycts_dev
DB_NAME=mycts
DB_CONNECTION_LIMIT=10
