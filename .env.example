# ========== 前端（Vite）==========
# 本地开发可用代理：填 /api，由 vite 转发到 3000 端口
VITE_API_BASE_URL=/api

# 生产环境填阿里云域名，例如：
# VITE_API_BASE_URL=https://你的域名/api

# 扫码 H5 公网地址（二维码里的域名）
# VITE_APP_SCAN_BASE_URL=https://你的域名

VITE_PORT=8888

# ========== Node 后端（Express）==========
PORT=3000

# 本地开发时 vite 代理目标
VITE_API_PROXY_TARGET=http://127.0.0.1:3000

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=mycts_user
DB_PASSWORD=your_password
DB_NAME=mycts
DB_CONNECTION_LIMIT=10

# 首次启动时自动创建的 admin 初始密码（仅当数据库里没有 admin 时生效）
DEFAULT_ADMIN_PASSWORD=admin@2023
