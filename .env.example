# Supabase（复制为 .env.local 并填入真实密钥，勿提交到 Git）
# 本项目是 Vite，必须用 VITE_ 前缀；Next.js 的 NEXT_PUBLIC_ 变量无效
#
# Next.js 文档写法 → 本项目对应写法：
# NEXT_PUBLIC_SUPABASE_URL              → VITE_SUPABASE_URL
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY  → VITE_SUPABASE_PUBLISHABLE_KEY

VITE_SUPABASE_URL=https://your-project.supabase.co
# 二选一：legacy anon JWT（eyJ...）或新版 publishable key（sb_publishable_...）
VITE_SUPABASE_ANON_KEY=eyJhbGci...
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# 扫码 H5 公网地址（Vercel 部署后填写，如 https://xxx.vercel.app）
VITE_APP_SCAN_BASE_URL=
